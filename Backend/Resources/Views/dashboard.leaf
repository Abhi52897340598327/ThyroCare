<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>#(title)</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            margin: 0;
            background: #e8faf5;
            color: #0b2239;
        }
        main {
            max-width: 860px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        section {
            background: white;
            border-radius: 8px;
            padding: 24px;
            box-shadow: 0 12px 32px rgba(11, 34, 57, 0.1);
        }
        code {
            background: rgba(15, 156, 156, 0.12);
            padding: 3px 6px;
            border-radius: 4px;
        }
    </style>
</head>
<body>
    <main>
        <section>
            <h1>#(title)</h1>
            <p>Status: <strong>#(status)</strong></p>
            <p>Meal analysis endpoint: <code>#(endpoint)</code></p>
        </section>
    </main>
</body>
</html>
